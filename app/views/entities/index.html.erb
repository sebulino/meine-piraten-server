<% content_for :title, "Gliederungen" %>

<div class="page-header">
  <h1>Gliederungen</h1>
  <% if admin? %>
    <%= link_to "Neue Gliederung", new_entity_path, class: "btn btn-primary" %>
  <% end %>
</div>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Gliederungsebene</th>
      <th>Übergeordnete Gliederung</th>
    </tr>
  </thead>

  <tbody>
    <% @entities.each do |entity| %>
      <tr>
        <td><%= link_to entity.name, entity %></td>
        <td><%= entity.entity_level_label %></td>
        <td><%= Entity.find_by(id: entity.entity_id)&.name %></td>
      </tr>
    <% end %>
  </tbody>
</table>
